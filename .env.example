VITE_API_BASE_URL=/api
VITE_USE_MOCK_FALLBACK=false

# For direct Spring Boot calls without the Vite proxy:
# VITE_API_BASE_URL=http://localhost:8080/api

# Set true only for frontend demos when the Spring Boot API is not running.
# Keep false for real frontend/backend integration.
# VITE_USE_MOCK_FALLBACK=true
